}

@keyframes rw-gp-animate-circle {
  to {
    stroke-dashoffset: 0;
  }
}

@keyframes rw-gp-expand-collapse {
  0% {
    transform: scale(1);
  }
  70% {
    transform: scale(1.2);
  }
  100% {
    transform: scale(1);
  }
}

